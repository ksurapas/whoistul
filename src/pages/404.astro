---
import BaseLayout from '../components/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Page Not Found — whoistul" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center py-24 sm:py-32 text-center">
    <p class="text-6xl sm:text-8xl font-bold font-display text-accent/20 select-none">404</p>
    <h1 class="mt-4 text-2xl sm:text-3xl font-semibold font-display text-text">
      Page not found
    </h1>
    <p class="mt-3 text-text-muted font-body text-lg max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href={`${base}/`}
      class="mt-8 inline-block px-6 py-3 text-sm font-medium text-card bg-accent rounded-lg hover:bg-accent-hover transition-colors duration-300 min-h-[44px] min-w-[44px]"
    >
      Back to Home
    </a>
  </div>
</BaseLayout>
