---
import BaseLayout from '../../components/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sports = [
  {
    name: 'Badminton',
    level: 'Intermediate',
    years: '8 years',
    frequency: '3x per week',
    gear: [
      { name: 'Yonex Astrox 88D Pro', type: 'Racket', note: 'Perfect power and control' },
      { name: 'Yonex Power Cushion 65Z', type: 'Shoes', note: 'Great court grip and cushioning' },
      { name: 'Yonex BG80', type: 'Strings', note: 'Excellent repulsion and durability' },
    ],
  },
  {
    name: 'Swimming',
    level: 'Advanced',
    years: '7 years',
    frequency: '2x per week',
    gear: [
      { name: 'Arena Cobra Ultra', type: 'Goggles', note: 'Low profile, great visibility' },
      { name: 'Speedo Fastskin', type: 'Jammers', note: 'Compression fit for training' },
    ],
  },
  {
    name: 'Running',
    level: 'Intermediate',
    years: '4 years',
    frequency: '2x per week',
    gear: [
      { name: 'Nike Vaporfly 3', type: 'Shoes', note: 'Race day carbon plate' },
      { name: 'Garmin Forerunner 265', type: 'Watch', note: 'Training metrics and GPS' },
    ],
  },
  {
    name: 'Gym',
    level: 'Regular',
    years: '5 years',
    frequency: '3x per week',
    gear: [
      { name: 'Nike Metcon 9', type: 'Shoes', note: 'Stable for lifting' },
      { name: 'Versa Gripps', type: 'Straps', note: 'Better grip on pulls' },
    ],
  },
];

const totalYears = sports.reduce((sum, s) => sum + parseInt(s.years), 0);
const totalWeekly = sports.reduce((sum, s) => sum + parseInt(s.frequency), 0);
const totalGear = sports.reduce((sum, s) => sum + s.gear.length, 0);
---

<BaseLayout
  title="Sports — Tul"
  description="Exploring my passion for athletics through various sports."
  currentPage="hobbies"
>
  <div class="pt-8 pb-20">
    <!-- Back link -->
    <a href={`${base}/hobbies`} class="inline-flex items-center gap-1 text-sm text-text-muted hover:text-accent transition-colors duration-200 mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      Hobbies
    </a>

    <h1 class="text-3xl md:text-4xl font-bold font-display text-text mb-2">Sports & Hobbies</h1>
    <p class="text-text-muted font-body mb-12 max-w-lg">
      Exploring my passion for athletics through various sports. Here's what I play, how often, and the gear that helps me perform at my best.
    </p>

    <!-- Sport cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8">
      {sports.map((sport) => (
        <div class="sport-card" data-sport={sport.name.toLowerCase()}>
          {/* Sport card */}
          <button
            class="sport-toggle w-full text-left rounded-2xl p-6 relative overflow-hidden h-44 flex flex-col justify-between bg-bg-alt border border-border hover:border-accent/30 hover:shadow-md transition-all duration-300"
            type="button"
            aria-expanded="false"
          >
            {/* Placeholder image area */}
            <div class="absolute inset-0 bg-bg-alt flex items-center justify-center">
              <svg class="w-16 h-16 text-text-muted/10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
            </div>

            <div class="relative z-10">
              <h3 class="text-2xl font-bold font-display text-text">{sport.name}</h3>
              <span class="inline-block mt-1 text-xs font-medium text-accent bg-accent/10 px-2.5 py-0.5 rounded-full">
                {sport.level}
              </span>
            </div>
            <div class="relative z-10 flex items-center gap-4 text-xs text-text-muted">
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {sport.years}
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                {sport.frequency}
              </span>
            </div>
            {/* Expand icon */}
            <div class="absolute top-5 right-5 w-8 h-8 rounded-full bg-bg/50 border border-border flex items-center justify-center">
              <svg class="w-4 h-4 text-text-muted sport-chevron transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
          </button>

          {/* Gear panel (hidden by default) */}
          <div class="sport-gear hidden mt-3 rounded-2xl border border-border bg-card p-5">
            <h4 class="text-sm font-semibold text-text mb-4">My Gear</h4>
            <div class="space-y-3">
              {sport.gear.map((item) => (
                <div class="flex items-start gap-3">
                  <div class="w-2 h-2 rounded-full bg-accent mt-1.5 flex-shrink-0"></div>
                  <div>
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-sm font-semibold text-text">{item.name}</span>
                      <span class="text-[10px] font-medium text-text-muted bg-bg-alt px-2 py-0.5 rounded">{item.type}</span>
                    </div>
                    <p class="text-xs text-text-muted mt-0.5">{item.note}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-12">
      {[
        { value: sports.length, label: 'Active Sports', color: 'text-accent' },
        { value: totalYears, label: 'Years Combined', color: 'text-accent' },
        { value: `${totalWeekly}x`, label: 'Weekly Sessions', color: 'text-accent' },
        { value: totalGear, label: 'Favorite Gear', color: 'text-accent' },
      ].map((stat) => (
        <div class="rounded-xl border border-border bg-card p-5 text-center">
          <p class:list={['text-2xl font-bold font-display', stat.color]}>{stat.value}</p>
          <p class="text-xs text-text-muted mt-1">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.sport-card').forEach((card) => {
    const toggle = card.querySelector('.sport-toggle');
    const gearPanel = card.querySelector('.sport-gear');
    const chevron = card.querySelector('.sport-chevron');

    toggle?.addEventListener('click', () => {
      const isOpen = !gearPanel?.classList.contains('hidden');

      document.querySelectorAll('.sport-card').forEach((other) => {
        if (other !== card) {
          other.querySelector('.sport-gear')?.classList.add('hidden');
          other.querySelector('.sport-toggle')?.setAttribute('aria-expanded', 'false');
          (other.querySelector('.sport-chevron') as HTMLElement)?.style.setProperty('transform', 'rotate(0deg)');
        }
      });

      if (isOpen) {
        gearPanel?.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        (chevron as HTMLElement)?.style.setProperty('transform', 'rotate(0deg)');
      } else {
        gearPanel?.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        (chevron as HTMLElement)?.style.setProperty('transform', 'rotate(180deg)');
      }
    });
  });
</script>
