---
import BaseLayout from '../../components/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Travel — Tul"
  description="Exploring new places with a camera and a loose itinerary."
  currentPage="hobbies"
>
  <div class="pt-8 pb-20">
    <a href={`${base}/hobbies`} class="inline-flex items-center gap-1 text-sm text-text-muted hover:text-accent transition-colors duration-200 mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      Hobbies
    </a>

    <div class="flex flex-col items-center justify-center py-24 text-center">
      <span class="text-6xl mb-6">✈️</span>
      <h1 class="text-3xl font-bold font-display text-text mb-3">Travel</h1>
      <p class="text-text-muted font-body max-w-md">
        This section is coming soon. I'm working on curating my favorite trips and travel stories.
      </p>
      <a href={`${base}/hobbies`} class="mt-8 text-sm text-accent hover:text-accent-hover transition-colors duration-200">
        ← Back to Hobbies
      </a>
    </div>
  </div>
</BaseLayout>
