---
import BaseLayout from '../../components/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const gadgets = [
  { name: 'iPhone 17 Pro', category: 'Phone', color: 'bg-rose-500' },
  { name: 'MacBook Air M2', category: 'Laptop', color: 'bg-blue-500' },
  { name: 'Nikon Z5II', category: 'Camera', color: 'bg-purple-500' },
  { name: 'Nikon D750', category: 'Camera', color: 'bg-purple-500' },
  { name: 'Magaosi K6 Pro', category: 'IEM', color: 'bg-teal-500' },
  { name: 'QK75', category: 'Keyboard', color: 'bg-amber-500' },
  { name: 'Keychron K2', category: 'Keyboard', color: 'bg-amber-500' },
  { name: 'Exclusive E7-V2', category: 'Keyboard', color: 'bg-amber-500' },
  { name: 'Garmin Fenix 8', category: 'Wearable', color: 'bg-orange-500' },
  { name: 'Philips Hue', category: 'Smart Home', color: 'bg-green-500' },
  { name: 'Sound Blaster G8', category: 'Audio', color: 'bg-teal-500' },
  { name: 'PlayStation 5', category: 'Gaming', color: 'bg-indigo-500' },
  { name: 'Edifier QR65', category: 'Speaker', color: 'bg-teal-500' },
  { name: 'Eloop EW54', category: 'Charger', color: 'bg-emerald-500' },
];
---

<BaseLayout
  title="Tech & Gadgets — Tul"
  description="My collection of tech purchases and favorite gadgets."
  currentPage="hobbies"
>
  <div class="pt-8 pb-20">
    <!-- Back link -->
    <a href={`${base}/hobbies`} class="inline-flex items-center gap-1 text-sm text-text-muted hover:text-accent transition-colors duration-200 mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      Hobbies
    </a>

    <h1 class="text-3xl md:text-4xl font-bold font-display text-text mb-2">Tech & Gadgets</h1>
    <p class="text-text-muted font-body mb-12">My collection of tech purchases and favorite gadgets</p>

    <!-- Gadget grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
      {gadgets.map((gadget) => (
        <div class="group rounded-2xl border border-border bg-card overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <!-- Image placeholder -->
          <div class="aspect-square bg-bg-alt flex items-center justify-center overflow-hidden">
            <svg class="w-12 h-12 text-text-muted/15 group-hover:scale-110 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
          </div>
          <!-- Info -->
          <div class="p-4">
            <span class:list={['inline-block text-[10px] font-semibold text-white px-2 py-0.5 rounded-full mb-2', gadget.color]}>
              {gadget.category}
            </span>
            <p class="font-semibold font-display text-text text-sm">{gadget.name}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
