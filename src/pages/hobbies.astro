---
import BaseLayout from '../components/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const hobbies = [
  {
    title: 'Photography',
    description: 'Capturing moments through the lens. Landscape and street photography.',
    href: `${base}/hobbies/photography`,
    icon: '📷',
    color: 'from-blue-500/20 to-indigo-500/20',
  },
  {
    title: 'Sports',
    description: 'Badminton, scuba diving, and staying active. The gear that keeps me going.',
    href: `${base}/hobbies/sports`,
    icon: '🏸',
    color: 'from-green-500/20 to-emerald-500/20',
  },
  {
    title: 'Tech & Gadgets',
    description: 'My collection of tech purchases and favorite gadgets.',
    href: `${base}/hobbies/tech`,
    icon: '💻',
    color: 'from-purple-500/20 to-pink-500/20',
  },
  {
    title: 'Travel',
    description: 'Exploring new places with a camera and a loose itinerary.',
    href: `${base}/hobbies/travel`,
    icon: '✈️',
    color: 'from-orange-500/20 to-amber-500/20',
    comingSoon: true,
  },
];
---

<BaseLayout
  title="Hobbies — Tul"
  description="Photography, sports, tech, and travel — the things that keep life interesting outside of work."
  currentPage="hobbies"
>
  <div class="pt-12 pb-20">
    <h1 class="text-3xl md:text-4xl font-bold font-display text-text text-center mb-3">
      Hobbies
    </h1>
    <p class="text-center text-text-muted font-body max-w-xl mx-auto mb-14">
      Work is a big part of who I am, but it's not the whole picture. These are the things I spend my time on outside of spreadsheets.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {hobbies.map((hobby) => (
        <a
          href={hobby.comingSoon ? undefined : hobby.href}
          class:list={[
            'group relative block rounded-2xl border border-border overflow-hidden transition-all duration-500',
            hobby.comingSoon
              ? 'opacity-50 cursor-not-allowed'
              : 'hover:shadow-xl hover:-translate-y-1 hover:border-accent/30',
          ]}
        >
          {/* Gradient background */}
          <div class:list={['absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500', hobby.color]}></div>

          <div class="relative p-8">
            <span class="text-4xl mb-4 block">{hobby.icon}</span>
            <h2 class="text-xl font-bold font-display text-text group-hover:text-accent transition-colors duration-300">
              {hobby.title}
              {hobby.comingSoon && <span class="ml-2 text-xs font-normal text-text-muted bg-bg-alt px-2 py-0.5 rounded-full">Coming soon</span>}
            </h2>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">{hobby.description}</p>

            {!hobby.comingSoon && (
              <div class="mt-4 flex items-center gap-1 text-sm text-accent font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                Explore
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
