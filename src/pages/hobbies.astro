---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import HobbyCard from '../components/HobbyCard.astro';
import HobbyDetail from '../components/HobbyDetail.astro';

// Fetch hobbies page metadata
const pagesEntries = await getCollection('pages');
const hobbiesPage = pagesEntries.find((p) => p.slug === 'hobbies');

// Fetch all hobby entries and sort by order
const hobbiesEntries = await getCollection('hobbies');
const sortedEntries = [...hobbiesEntries].sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

type HobbyCategory = 'photography' | 'travel' | 'sports' | 'motorsport';

// Group by category (take first entry per category for detail sections)
const byCategory = new Map<HobbyCategory, (typeof sortedEntries)[number]>();
for (const entry of sortedEntries) {
  const cat = entry.data.category as HobbyCategory;
  if (!byCategory.has(cat)) {
    byCategory.set(cat, entry);
  }
}

const photography = byCategory.get('photography');
const travel = byCategory.get('travel');
const sports = byCategory.get('sports');
const motorsport = byCategory.get('motorsport');

const photographyContent = photography ? await photography.render() : null;
const travelContent = travel ? await travel.render() : null;
const sportsContent = sports ? await sports.render() : null;
const motorsportContent = motorsport ? await motorsport.render() : null;

// All entries for the masonry grid
const cardEntries = sortedEntries.map((entry) => ({
  title: entry.data.title,
  category: entry.data.category,
  description: entry.data.description,
  slug: entry.data.category,
}));
---

<BaseLayout
  title="Hobbies — Tul"
  description={hobbiesPage?.data.description ?? 'Photography, travel, badminton, and Formula 1 — the things that keep life interesting outside of work.'}
  currentPage="hobbies"
>
  <!-- Header -->
  <div class="pt-12 pb-6 text-center">
    <h1 class="text-3xl md:text-4xl font-bold font-display text-text mb-4">
      Hobbies
    </h1>
    {hobbiesPage?.data.description && (
      <p class="text-text-muted font-body max-w-2xl mx-auto">
        {hobbiesPage.data.description}
      </p>
    )}
  </div>

  <!-- Chester.how-style masonry card grid -->
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4">
      {cardEntries.map((entry) => (
        <div class="break-inside-avoid">
          <HobbyCard
            title={entry.title}
            category={entry.category}
            description={entry.description}
            href={`#${entry.slug}`}
          />
        </div>
      ))}
    </div>
  </div>

  <!-- Sticky nav -->
  <nav class="sticky top-0 z-40 bg-bg/90 backdrop-blur-sm border-y border-border" aria-label="Hobby sections">
    <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">
      <ul class="flex items-center gap-2 sm:gap-6 overflow-x-auto py-3">
        {['Photography', 'Travel', 'Sports', 'Motorsport'].map((label) => (
          <li class="flex-shrink-0">
            <a
              href={`#${label.toLowerCase()}`}
              class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-text-muted rounded-full transition-all duration-300 hover:text-accent hover:bg-accent/10 whitespace-nowrap min-h-[44px]"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- Detail sections -->
  <HobbyDetail id="photography" title={photography?.data.title ?? 'Photography'} description={photography?.data.description}>
    {photographyContent && <photographyContent.Content />}
  </HobbyDetail>

  <HobbyDetail id="travel" title={travel?.data.title ?? 'Travel'} description={travel?.data.description} altBg>
    {travelContent && <travelContent.Content />}
  </HobbyDetail>

  <HobbyDetail id="sports" title={sports?.data.title ?? 'Sports'} description={sports?.data.description}>
    {sportsContent && <sportsContent.Content />}
  </HobbyDetail>

  <HobbyDetail id="motorsport" title={motorsport?.data.title ?? 'Motorsport'} description={motorsport?.data.description} altBg>
    {motorsportContent && <motorsportContent.Content />}
  </HobbyDetail>
</BaseLayout>
