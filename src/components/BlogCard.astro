---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate } from '../lib/utils';

interface Props {
  title: string;
  date: Date;
  slug: string;
  excerpt?: string;
  coverImage?: ImageMetadata;
}

const { title, date, slug, excerpt, coverImage } = Astro.props;
---

<a
  href={`/blog/${slug}`}
  aria-label={title}
  class="blog-card block bg-card border border-border rounded-lg overflow-hidden transition-all duration-300 ease-in-out hover:scale-[1.02] hover:shadow-md"
>
  {coverImage && (
    <div class="aspect-video overflow-hidden bg-bg-alt">
      <Image
        src={coverImage}
        alt=""
        width={coverImage.width}
        height={coverImage.height}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>
  )}
  <div class="p-4 sm:p-6">
    <time datetime={date.toISOString()} class="text-sm text-text-muted font-body">
      {formatDate(date)}
    </time>
    <h3 class="mt-2 text-lg font-semibold text-text font-display">{title}</h3>
    {excerpt && (
      <p class="mt-2 text-sm text-text-muted font-body leading-relaxed">{excerpt}</p>
    )}
  </div>
</a>
