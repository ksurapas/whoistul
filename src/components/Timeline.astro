---
import type { ImageMetadata } from 'astro';
import Section from './Section.astro';
import TimelineItem from './TimelineItem.astro';

interface TimelineMilestone {
  title: string;
  subtitle?: string;
  date: string;
  description: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

interface Props {
  milestones: TimelineMilestone[];
}

const { milestones } = Astro.props;
---

<Section id="timeline">
  {milestones.length > 0 ? (
    <div class="relative">
      {/* Vertical spine */}
      <div class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5 bg-border" aria-hidden="true"></div>

      <div class="space-y-12">
        {milestones.map((milestone, index) => (
          <div class:list={[
            'relative flex flex-col md:flex-row md:items-start',
            index % 2 === 0 ? 'md:flex-row-reverse' : '',
          ]}>
            {/* Dot on the spine */}
            <div class="absolute left-4 md:left-1/2 -translate-x-1/2 top-1 w-3 h-3 rounded-full bg-accent border-2 border-bg z-10" aria-hidden="true"></div>

            {/* Content */}
            <div class:list={[
              'ml-10 md:ml-0 md:w-[calc(50%-2rem)]',
              index % 2 === 0 ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8',
            ]}>
              <div class="bg-card rounded-lg p-6 shadow-sm border border-border">
                <TimelineItem
                  title={milestone.title}
                  subtitle={milestone.subtitle}
                  date={milestone.date}
                  description={milestone.description}
                  image={milestone.image}
                  imageAlt={milestone.imageAlt}
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  ) : (
    <p class="text-center text-text-muted font-body">No milestones yet. Check back soon.</p>
  )}
</Section>
