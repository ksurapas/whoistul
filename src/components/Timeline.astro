---
import Section from './Section.astro';
import ImageCarousel from './ImageCarousel.astro';

interface TimelineMilestone {
  title: string;
  subtitle?: string;
  date: string;
  description: string;
  imageCount?: number;
  id: string;
}

interface Props {
  milestones: TimelineMilestone[];
}

const { milestones } = Astro.props;
---

<Section id="timeline">
  {milestones.length > 0 ? (
    <div class="space-y-24">
      {milestones.map((milestone, index) => {
        const imageOnRight = index % 2 === 0;
        return (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
            {/* Text side */}
            <div class:list={[imageOnRight ? 'md:order-1' : 'md:order-2']}>
              <span class="inline-block text-sm font-body text-text-muted mb-3 px-3 py-1 bg-bg-alt rounded-full">
                {milestone.date}
              </span>
              <h3 class="text-2xl md:text-3xl font-bold font-display text-text leading-tight">
                {milestone.title}
              </h3>
              {milestone.subtitle && (
                <p class="text-lg font-medium text-accent mt-1">{milestone.subtitle}</p>
              )}
              <p class="text-base font-body text-text-muted leading-relaxed mt-4">
                {milestone.description}
              </p>
            </div>

            {/* Image carousel side */}
            <div class:list={[imageOnRight ? 'md:order-2' : 'md:order-1']}>
              <ImageCarousel id={milestone.id} placeholderCount={milestone.imageCount ?? 3} />
            </div>
          </div>
        );
      })}
    </div>
  ) : (
    <p class="text-center text-text-muted font-body">No milestones yet. Check back soon.</p>
  )}
</Section>
