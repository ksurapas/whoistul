---
import Section from './Section.astro';
import ImageCarousel from './ImageCarousel.astro';

interface TimelineMilestone {
  title: string;
  subtitle?: string;
  date: string;
  description: string;
  imageCount?: number;
  id: string;
}

interface Props {
  milestones: TimelineMilestone[];
}

const { milestones } = Astro.props;
---

<Section id="timeline" class="!px-0">
  {milestones.length > 0 ? (
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
      {/* Center vertical line */}
      <div class="hidden md:block absolute left-1/2 -translate-x-[1.5px] top-0 bottom-0 w-[3px] bg-border" aria-hidden="true"></div>

      <div class="space-y-0">
        {milestones.map((milestone, index) => {
          const textOnLeft = index % 2 === 0;
          return (
            <div class="relative md:flex md:items-start pb-20 last:pb-0">
              {/* Dot — aligned with center of image carousel */}
              <div class="hidden md:block absolute left-1/2 -translate-x-1/2 top-[160px] -translate-y-1/2 z-10">
                <div class="w-5 h-5 rounded-full bg-text border-4 border-bg shadow-md"></div>
              </div>

              {textOnLeft ? (
                <>
                  {/* Text on left */}
                  <div class="md:w-1/2 md:pr-10 md:text-right">
                    <span class="inline-block text-sm font-body text-text-muted mb-2 px-3 py-1 bg-bg-alt rounded-full">
                      {milestone.date}
                    </span>
                    <h3 class="text-xl sm:text-2xl font-bold font-display text-text leading-tight">
                      {milestone.title}
                    </h3>
                    {milestone.subtitle && (
                      <p class="text-base font-medium text-accent mt-0.5">{milestone.subtitle}</p>
                    )}
                    <p class="text-sm sm:text-base font-body text-text-muted leading-relaxed mt-3">
                      {milestone.description}
                    </p>
                  </div>
                  {/* Image on right */}
                  <div class="md:w-1/2 md:pl-10 mt-4 md:mt-0">
                    <ImageCarousel id={milestone.id} placeholderCount={milestone.imageCount ?? 3} />
                  </div>
                </>
              ) : (
                <>
                  {/* Image on left */}
                  <div class="md:w-1/2 md:pr-10">
                    <ImageCarousel id={`${milestone.id}-left`} placeholderCount={milestone.imageCount ?? 3} />
                  </div>
                  {/* Text on right */}
                  <div class="md:w-1/2 md:pl-10 mt-4 md:mt-0">
                    <span class="inline-block text-sm font-body text-text-muted mb-2 px-3 py-1 bg-bg-alt rounded-full">
                      {milestone.date}
                    </span>
                    <h3 class="text-xl sm:text-2xl font-bold font-display text-text leading-tight">
                      {milestone.title}
                    </h3>
                    {milestone.subtitle && (
                      <p class="text-base font-medium text-accent mt-0.5">{milestone.subtitle}</p>
                    )}
                    <p class="text-sm sm:text-base font-body text-text-muted leading-relaxed mt-3">
                      {milestone.description}
                    </p>
                  </div>
                </>
              )}
            </div>
          );
        })}
      </div>
    </div>
  ) : (
    <p class="text-center text-text-muted font-body">No milestones yet. Check back soon.</p>
  )}
</Section>
