---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  width,
  height,
  class: className,
  loading = 'lazy',
} = Astro.props;
---

<div class:list={['optimized-image-wrapper', className]}>
  <Image
    src={src}
    alt={alt}
    width={width ?? src.width}
    height={height ?? src.height}
    loading={loading}
    class="optimized-image"
  />
</div>

<style>
  .optimized-image-wrapper {
    background-color: var(--color-bg-alt);
    overflow: hidden;
  }

  .optimized-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }
</style>
