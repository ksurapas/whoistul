---
import Section from './Section.astro';
import ContentCard from './ContentCard.astro';

interface FeaturedItem {
  title: string;
  description?: string;
  href?: string;
}

interface Props {
  items: FeaturedItem[];
}

const { items } = Astro.props;
const displayItems = items.slice(0, 3);
---

<Section id="featured">
  <h2 class="text-2xl md:text-3xl font-semibold font-display text-text text-center mb-8">
    Featured
  </h2>
  {displayItems.length > 0 ? (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {displayItems.map((item) => (
        <ContentCard
          title={item.title}
          description={item.description}
          href={item.href}
        />
      ))}
    </div>
  ) : (
    <p class="text-center text-text-muted font-body">Nothing featured yet. Check back soon.</p>
  )}
</Section>
