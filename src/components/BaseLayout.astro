---
import SEOHead from './SEOHead.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  currentPage?: string;
}

const { title, description, ogImage, currentPage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEOHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-text font-body">
    <header>
      <Navbar currentPage={currentPage} />
    </header>

    <main class="flex-1 w-full max-w-content mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <footer>
      <Footer />
    </footer>
  </body>
</html>
