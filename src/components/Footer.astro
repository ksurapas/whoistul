---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { label: 'GitHub', href: 'https://github.com/whoistul', icon: 'github' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/whoistul', icon: 'linkedin' },
];
---

<div class="w-full max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-8 border-t border-border">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-text-muted">
      &copy; {currentYear} Tul. All rights reserved.
    </p>

    {socialLinks.length > 0 && (
      <ul class="flex items-center gap-6" aria-label="Social links">
        {socialLinks.map((link) => (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-text-muted hover:text-accent transition-colors duration-300"
              aria-label={link.label}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</div>
