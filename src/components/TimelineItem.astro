---
import type { ImageMetadata } from 'astro';
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  title: string;
  date: string;
  description: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { title, date, description, image, imageAlt } = Astro.props;
---

<div class="timeline-item">
  {image && (
    <div class="mb-4 rounded-lg overflow-hidden">
      <OptimizedImage
        src={image}
        alt={imageAlt ?? title}
        class="w-full rounded-lg"
      />
    </div>
  )}
  <time class="block text-sm font-body text-text-muted mb-1">{date}</time>
  <h3 class="text-xl font-semibold font-display text-text mb-2">{title}</h3>
  <p class="text-base font-body text-text-muted leading-relaxed">{description}</p>
</div>
